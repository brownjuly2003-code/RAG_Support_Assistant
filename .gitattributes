# Default: normalize text to LF in the repository
* text=auto eol=lf

# Explicit text types: always LF
*.py    text eol=lf
*.md    text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.json  text eol=lf
*.toml  text eol=lf
*.ini   text eol=lf
*.cfg   text eol=lf
*.sh    text eol=lf
*.sql   text eol=lf
*.html  text eol=lf
*.css   text eol=lf
*.js    text eol=lf

# Windows-specific scripts
*.bat   text eol=crlf
*.cmd   text eol=crlf
*.ps1   text eol=lf

# Binary files: do not touch
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.pdf   binary
*.db    binary
*.sqlite binary
*.whl   binary
*.gz    binary
*.zip   binary
